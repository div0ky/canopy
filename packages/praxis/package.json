{
  "name": "@doxajs/praxis",
  "version": "0.1.0-alpha.17",
  "description": "The canonical generator, development, runtime, inspection, and operations CLI for Doxa.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/div0ky/doxajs.git",
    "directory": "packages/praxis"
  },
  "homepage": "https://github.com/div0ky/doxajs#readme",
  "bugs": {
    "url": "https://github.com/div0ky/doxajs/issues"
  },
  "keywords": [
    "doxa",
    "framework",
    "cli",
    "generator",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.7 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "doxa": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hot-reload": {
      "types": "./dist/hot-reload.d.ts",
      "default": "./dist/hot-reload.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "doxaCompatibility": {
    "schemaVersion": 1,
    "channel": "alpha",
    "frameworkPackages": [
      "@doxajs/auth-postgres",
      "@doxajs/compiler",
      "@doxajs/core",
      "@doxajs/gnosis",
      "@doxajs/http-hono",
      "@doxajs/introspection",
      "@doxajs/keryx",
      "@doxajs/manifest",
      "@doxajs/opentelemetry",
      "@doxajs/postgres-drizzle",
      "@doxajs/praxis",
      "@doxajs/queue-pg-boss",
      "@doxajs/realtime",
      "@doxajs/runtime",
      "@doxajs/sendgrid",
      "@doxajs/testing",
      "@doxajs/theoria",
      "@doxajs/twilio-sms"
    ],
    "toolchain": {
      "node": ">=24.7 <25",
      "packageManager": "pnpm@11.10.0",
      "devDependencies": {
        "@types/node": "^24.0.0",
        "typescript": "^6.0.0",
        "vitest": "^4.0.0"
      }
    },
    "upgradeRecipes": [
      "framework-owned-application-core",
      "gnosis-agent-registration"
    ]
  },
  "scripts": {
    "prepack": "node ../../scripts/prepare-package.mjs",
    "postpack": "node ../../scripts/prepare-package.mjs --clean"
  },
  "dependencies": {
    "@doxajs/core": "workspace:*",
    "@doxajs/http-hono": "workspace:*",
    "@doxajs/introspection": "workspace:*",
    "@doxajs/queue-pg-boss": "workspace:*",
    "@doxajs/runtime": "workspace:*",
    "pg": "8.22.0"
  },
  "optionalDependencies": {
    "@doxajs/compiler": "workspace:*",
    "@doxajs/gnosis": "workspace:*",
    "@doxajs/theoria": "workspace:*",
    "typescript": "6.0.2"
  },
  "devDependencies": {
    "@types/pg": "8.20.0"
  }
}
