{
  "name": "@canopy/http-hono",
  "version": "0.1.0-alpha.0",
  "description": "The first-party Hono HTTP engine and Node host adapter for Canopy.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/div0ky/canopy.git",
    "directory": "packages/http-hono"
  },
  "homepage": "https://github.com/div0ky/canopy#readme",
  "bugs": {
    "url": "https://github.com/div0ky/canopy/issues"
  },
  "keywords": [
    "canopy",
    "framework",
    "hono",
    "http",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "prepack": "node ../../scripts/prepare-package.mjs",
    "postpack": "node ../../scripts/prepare-package.mjs --clean"
  },
  "dependencies": {
    "@canopy/core": "workspace:*",
    "@canopy/runtime": "workspace:*",
    "@hono/node-server": "2.0.8",
    "hono": "4.12.29"
  }
}
