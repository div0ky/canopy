{
  "name": "@canopy/compiler",
  "version": "0.1.0-alpha.0",
  "description": "The fail-closed semantic TypeScript compiler for Canopy applications.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/div0ky/canopy.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/div0ky/canopy#readme",
  "bugs": {
    "url": "https://github.com/div0ky/canopy/issues"
  },
  "keywords": [
    "canopy",
    "framework",
    "compiler",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "prepack": "node ../../scripts/prepare-package.mjs",
    "postpack": "node ../../scripts/prepare-package.mjs --clean"
  },
  "dependencies": {
    "@canopy/manifest": "workspace:*",
    "typescript": "6.0.2"
  }
}
