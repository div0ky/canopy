{
  "name": "@canopy/manifest",
  "version": "0.1.0-alpha.0",
  "description": "Versioned, inert application manifest contracts for the Canopy framework.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/div0ky/canopy.git",
    "directory": "packages/manifest"
  },
  "homepage": "https://github.com/div0ky/canopy#readme",
  "bugs": {
    "url": "https://github.com/div0ky/canopy/issues"
  },
  "keywords": [
    "canopy",
    "framework",
    "manifest",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "prepack": "node ../../scripts/prepare-package.mjs",
    "postpack": "node ../../scripts/prepare-package.mjs --clean"
  }
}
