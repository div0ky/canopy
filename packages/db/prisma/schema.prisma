generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  draft
  submitted
  paid
  cancelled
}

enum OutboxStatus {
  pending
  processing
  published
  dead
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  name          String
  passwordHash  String         @map("password_hash")
  sessionVersion Int           @default(1) @map("session_version")
  orders        Order[]
  notifications Notification[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Order {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  number      String            @unique
  status      OrderStatus       @default(draft)
  totalCents  Int               @map("total_cents")
  notes       String?
  version     Int               @default(1)
  attachments OrderAttachment[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  @@index([userId, createdAt, id])
  @@index([status, updatedAt])
  @@map("orders")
}

model OrderAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  disk      String
  path      String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_attachments")
}

model DomainEventJournal {
  id            String   @id @db.Uuid
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id") @db.Uuid
  aggregateVersion Int   @map("aggregate_version")
  eventType     String   @map("event_type")
  eventVersion  Int      @map("event_version")
  payload       Json
  metadata      Json
  occurredAt    DateTime @map("occurred_at")
  recordedAt    DateTime @default(now()) @map("recorded_at")

  @@unique([aggregateType, aggregateId, aggregateVersion, eventType])
  @@index([eventType, recordedAt])
  @@map("domain_event_journal")
}

model FrameworkOutbox {
  id            String       @id @db.Uuid
  topic         String
  eventType     String       @map("event_type")
  eventVersion  Int          @map("event_version")
  payload       Json
  metadata      Json
  status        OutboxStatus @default(pending)
  attempts      Int          @default(0)
  availableAt   DateTime     @default(now()) @map("available_at")
  lockedAt      DateTime?    @map("locked_at")
  lockedBy      String?      @map("locked_by")
  leaseExpiresAt DateTime?   @map("lease_expires_at")
  publishedAt   DateTime?    @map("published_at")
  lastError     String?      @map("last_error")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([status, availableAt])
  @@index([leaseExpiresAt])
  @@map("framework_outbox")
}

model FailedJob {
  id         String   @id @default(uuid()) @db.Uuid
  queue      String
  jobName    String   @map("job_name")
  jobId      String   @map("job_id")
  payload    Json
  error      String
  failedAt   DateTime @default(now()) @map("failed_at")
  retriedAt  DateTime? @map("retried_at")

  @@unique([queue, jobId])
  @@map("framework_failed_jobs")
}

model Notification {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  data         Json
  readAt       DateTime? @map("read_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("notifications")
}

