{
  "name": "@evergreen/canopy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "bin": {
    "canopy": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./dist/testing/index.js"
    },
    "./adapters": {
      "types": "./src/adapters/index.ts",
      "default": "./dist/adapters/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.840.0",
    "@aws-sdk/s3-request-presigner": "^3.840.0",
    "@evergreen/canopy-jobs": "workspace:*",
    "@evergreen/db": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/cqrs": "^11.0.3",
    "@sendgrid/mail": "^8.1.5",
    "ably": "^2.10.0",
    "bullmq": "^5.56.0",
    "commander": "^14.0.0",
    "ioredis": "5.10.1",
    "jose": "^6.0.11",
    "pino": "^9.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "twilio": "^5.7.2",
    "zod": "^3.25.67"
  }
}
