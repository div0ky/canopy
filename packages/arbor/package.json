{
  "name": "@canopy/arbor",
  "version": "0.1.0-alpha.0",
  "description": "The canonical generator, development, runtime, inspection, and operations CLI for Canopy.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/div0ky/canopy.git",
    "directory": "packages/arbor"
  },
  "homepage": "https://github.com/div0ky/canopy#readme",
  "bugs": {
    "url": "https://github.com/div0ky/canopy/issues"
  },
  "keywords": [
    "canopy",
    "framework",
    "cli",
    "generator",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "arbor": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hot-reload": {
      "types": "./dist/hot-reload.d.ts",
      "default": "./dist/hot-reload.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "prepack": "node ../../scripts/prepare-package.mjs",
    "postpack": "node ../../scripts/prepare-package.mjs --clean"
  },
  "dependencies": {
    "@canopy/core": "workspace:*",
    "@canopy/http-hono": "workspace:*",
    "@canopy/queue-pg-boss": "workspace:*",
    "@canopy/runtime": "workspace:*",
    "pg": "8.22.0"
  },
  "optionalDependencies": {
    "@canopy/compiler": "workspace:*",
    "@canopy/undergrowth": "workspace:*",
    "drizzle-kit": "0.31.10"
  },
  "devDependencies": {
    "@types/pg": "8.20.0"
  }
}
