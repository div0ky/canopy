{
  "name": "@canopy/auth-postgres",
  "version": "0.1.0-alpha.0",
  "description": "First-party PostgreSQL email/password, session, and bearer authentication for Canopy.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/div0ky/canopy.git",
    "directory": "packages/auth-postgres"
  },
  "homepage": "https://github.com/div0ky/canopy#readme",
  "bugs": {
    "url": "https://github.com/div0ky/canopy/issues"
  },
  "keywords": [
    "canopy",
    "framework",
    "authentication",
    "postgresql",
    "security"
  ],
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "NOTICE"
  ],
  "scripts": {
    "prepack": "node ../../scripts/prepare-package.mjs",
    "postpack": "node ../../scripts/prepare-package.mjs --clean"
  },
  "dependencies": {
    "@canopy/core": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0"
  }
}
