{
  "name": "@doxajs/keryx",
  "version": "0.1.0-alpha.22",
  "description": "Doxa's first-party authenticated WebSocket broadcasting server.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/div0ky/doxajs.git",
    "directory": "packages/keryx"
  },
  "homepage": "https://github.com/div0ky/doxajs#readme",
  "bugs": {
    "url": "https://github.com/div0ky/doxajs/issues"
  },
  "keywords": [
    "doxa",
    "framework",
    "websocket",
    "broadcasting",
    "realtime"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.7 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "scripts": {
    "prepack": "node ../../scripts/prepare-package.mjs",
    "postpack": "node ../../scripts/prepare-package.mjs --clean"
  },
  "dependencies": {
    "@doxajs/core": "workspace:*",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/ws": "8.18.1"
  }
}
