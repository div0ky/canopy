---
interface Props {
  inverse?: boolean
  position?: 'left' | 'right'
}

const { inverse = false, position = 'left' } = Astro.props
---

<div
  aria-hidden="true"
  class:list={[
    'pointer-events-none absolute top-0 bottom-0 hidden w-32 overflow-hidden xl:block',
    position === 'left' ? 'left-0' : 'right-0 rotate-180',
    inverse ? 'text-paper/25' : 'text-rule',
  ]}
>
  <div class="absolute top-0 bottom-0 left-8 w-px bg-current"></div>
  <div class="absolute top-[45%] left-0 h-px w-28 bg-current"></div>
  <div class="absolute top-[22%] -left-24 size-44 rounded-full border border-current"></div>
  <div class="absolute top-[45%] left-8 size-16 border border-current"></div>
  <div class="absolute top-[calc(45%+1rem)] left-12 size-8 rounded-full border border-current">
  </div>
  <span class="absolute top-[45%] left-[1.72rem] size-2 bg-oxblood"></span>
</div>
