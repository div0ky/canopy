---
interface Props {
  inverse?: boolean
}

const { inverse = false } = Astro.props
---

<a
  href="#top"
  aria-label="Doxa.js home"
  class:list={[
    'group inline-flex items-baseline font-display text-[2rem] leading-none tracking-[-0.055em] no-underline',
    inverse ? 'text-paper' : 'text-ink',
  ]}
>
  <span class="text-oxblood transition-colors group-hover:text-oxblood-dark">doxa</span><span
    class="text-[0.62em] tracking-[-0.04em]">.js</span
  >
</a>
