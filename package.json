{
  "name": "canopy-framework",
  "version": "0.1.0-alpha.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -b",
    "arbor": "node packages/arbor/dist/bin.js",
    "audit:boundaries": "node scripts/check-boundaries.mjs",
    "audit:docs": "node scripts/check-doc-links.mjs",
    "audit:security": "pnpm audit --prod --audit-level=moderate",
    "audit:mvp": "pnpm check && pnpm check:field-guide && pnpm test && pnpm audit:boundaries && pnpm audit:docs",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "ci": "pnpm verify",
    "check": "tsc -b --pretty false && tsc -p tsconfig.tests.json --noEmit --pretty false",
    "clean": "tsc -b --clean",
    "dev": "node --env-file-if-exists=.env scripts/dev-supervisor.mjs",
    "dev:field-guide": "pnpm --filter @canopy/field-guide dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint packages tests scripts examples/reference-app/src examples/persistence-app/src",
    "lint:fix": "pnpm lint --fix",
    "package:check": "pnpm build && node scripts/check-packages.mjs",
    "release": "pnpm verify && changeset publish --tag next",
    "build:field-guide": "pnpm --filter @canopy/field-guide build",
    "check:field-guide": "pnpm --filter @canopy/field-guide lint && pnpm --filter @canopy/field-guide build",
    "test": "pnpm build && tsc -p tsconfig.tests.json --noEmit --pretty false && vitest run",
    "test:coverage": "pnpm build && vitest run --coverage",
    "test:watch": "vitest",
    "verify": "pnpm format:check && pnpm lint && pnpm check && pnpm check:field-guide && pnpm test:coverage && pnpm audit:boundaries && pnpm audit:docs && pnpm changeset:status && pnpm package:check && pnpm audit:security"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@canopy/arbor": "workspace:*",
    "@canopy/auth-postgres": "workspace:*",
    "@canopy/compiler": "workspace:*",
    "@canopy/core": "workspace:*",
    "@canopy/http-hono": "workspace:*",
    "@canopy/postgres-drizzle": "workspace:*",
    "@canopy/queue-pg-boss": "workspace:*",
    "@canopy/runtime": "workspace:*",
    "@canopy/sendgrid": "workspace:*",
    "@canopy/testing": "workspace:*",
    "@canopy/twilio-sms": "workspace:*",
    "@canopy/undergrowth": "workspace:*",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "pg": "8.22.0",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
