{
  "name": "canopy-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present run clean",
    "dev:api": "pnpm --filter @canopy/api dev",
    "dev:worker": "pnpm --filter @canopy/worker dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:generate": "pnpm --filter @evergreen/db generate",
    "db:migrate": "pnpm --filter @evergreen/db migrate",
    "db:seed": "pnpm --filter @evergreen/db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.30.1",
    "eslint-plugin-import-x": "^4.16.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "supertest": "^7.1.1",
    "socket.io-client": "^4.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
